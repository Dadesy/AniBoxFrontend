# URL бэкенда (NestJS API)
NUXT_PUBLIC_API_URL=http://localhost:8080/api

# SSR обращается к бэкенду напрямую (Node-to-Node, не через браузер)
# В production замените на внутренний URL контейнера: http://backend:8080/api
NUXT_API_URL_INTERNAL=http://localhost:8080/api

# Публичный URL сайта без слэша в конце (canonical, OG, динамические /robots.txt и /sitemap.xml)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Имя бренда в шапке, title страниц, письмах (синхронизируйте с APP_NAME на бэкенде)
NUXT_PUBLIC_SITE_NAME=AnimeScope

# Yandex.Metrika (пусто или 0 — отключить)
NUXT_PUBLIC_YANDEX_METRIKA_ID=108180420

# Dadesy: подтверждение сайта — файл public/cdnmovies.txt (одна строка = ваш логин).
# Отредактируйте nuxt-app/public/cdnmovies.txt и подставьте логин вместо плейсхолдера, затем пересоберите/задеплойте.
